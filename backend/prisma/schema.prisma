// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  firebaseUid  String?        @unique
  email        String         @unique
  name         String?
  streak       Int            @default(0)
  targetWeekly Int            @default(80)
  createdAt    DateTime       @default(now())
  updatedAt        DateTime         @updatedAt
  sessions         StudySession[]
  userVocabularies UserVocabulary[]
  reviewHistories  ReviewHistory[]
}

model VocabularyPackage {
  id          String       @id @default(uuid())
  title       String
  description String?
  level       String       @default("All Levels")
  isPro       Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  vocabularies Vocabulary[]
}

model Vocabulary {
  id               String           @id @default(uuid())
  word             String
  meaning          String
  ipa              String?
  example          String?
  packageId        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  
  package          VocabularyPackage? @relation(fields: [packageId], references: [id])
  userVocabularies UserVocabulary[]
  reviewHistories  ReviewHistory[]
}

model UserVocabulary {
  id           String     @id @default(uuid())
  userId       String
  vocabularyId String
  level        Int        @default(1)
  nextReview   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user         User       @relation(fields: [userId], references: [id])
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id])

  @@unique([userId, vocabularyId])
}

model StudySession {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime @default(now())
  durationMinutes Int      @default(0)
  wordsLearned    Int      @default(0)
  user            User     @relation(fields: [userId], references: [id])
}

model ReviewHistory {
  id             String   @id @default(uuid())
  userId         String
  vocabularyId   String
  reviewedAt     DateTime @default(now())
  isCorrect      Boolean
  previousLevel  Int
  newLevel       Int

  user           User       @relation(fields: [userId], references: [id])
  vocabulary     Vocabulary @relation(fields: [vocabularyId], references: [id])
}
